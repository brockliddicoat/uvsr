+static constexpr float UvsrComboPopupRollDuration = 0.18f;
+static constexpr float UvsrComboPopupMaximumDelta = 1.0f / 30.0f;
+
+static float AdvanceComboPopupRollElapsed(float elapsed, float delta_time)
+{
+    return ImMin(
+        UvsrComboPopupRollDuration,
+        elapsed + ImMin(
+            ImMax(delta_time, 0.0f),
+            UvsrComboPopupMaximumDelta));
+}
+
+static float SmoothComboPopupRoll(float elapsed)
+{
+    const float progress = ImSaturate(
+        elapsed / UvsrComboPopupRollDuration);
+    return progress * progress * (3.0f - 2.0f * progress);
+}
+
+static void ApplyComboPopupRollClip(ImGuiWindow* window)
+{
+    if (!IsComboPopupWindow(window))
+        return;
+
+    const float amount = ImSaturate(window->StateStorage.GetFloat(
+        ImHashStr("##ComboPopupRollAmount"),
+        1.0f));
+    if (amount >= 1.0f)
+        return;
+
+    const bool roll_from_bottom = window->StateStorage.GetInt(
+        ImHashStr("##ComboPopupRollFromBottom"),
+        0) != 0;
+    const float top = window->Pos.y;
+    const float bottom = window->Pos.y + window->Size.y;
+    const float boundary = IM_ROUND(
+        roll_from_bottom
+            ? ImLerp(bottom, top, amount)
+            : ImLerp(top, bottom, amount));
+
+    for (int command_index = 0;
+        command_index < window->DrawList->CmdBuffer.Size;
+        ++command_index)
+    {
+        ImDrawCmd& command =
+            window->DrawList->CmdBuffer[command_index];
+        if (roll_from_bottom)
+            command.ClipRect.y = ImMax(command.ClipRect.y, boundary);
+        else
+            command.ClipRect.w = ImMin(command.ClipRect.w, boundary);
+        if (command.ClipRect.w < command.ClipRect.y)
+            command.ClipRect.w = command.ClipRect.y;
+    }
+}
+
+bool ImGui::IsComboPopupTransitionActive(ImGuiID combo_id)
+{
+    if (combo_id == 0)
+        return false;
+
+    ImGuiContext& g = *GImGui;
+    const ImGuiID popup_id = ImHashStr("##ComboPopup", 0, combo_id);
+    for (int popup_index = 0;
+        popup_index < g.OpenPopupStack.Size;
+        ++popup_index)
+    {
+        const ImGuiPopupData& popup_data =
+            g.OpenPopupStack[popup_index];
+        if (popup_data.PopupId != popup_id)
+            continue;
+        ImGuiWindow* window = popup_data.Window;
+        if (!IsComboPopupWindow(window))
+            return true;
+        if (window->StateStorage.GetInt(
+                ImHashStr("##ComboPopupClosing"),
+                0) != 0 ||
+            window->StateStorage.GetInt(
+                ImHashStr("##ComboPopupInteractionReady"),
+                0) == 0)
+        {
+            return true;
+        }
+    }
+    return false;
+}
+
+void ImGui::FinishComboPopupTransition(ImGuiID combo_id)
+{
+    if (combo_id == 0)
+        return;
+
+    ImGuiContext& g = *GImGui;
+    const ImGuiID popup_id = ImHashStr("##ComboPopup", 0, combo_id);
+    for (int popup_index = 0;
+        popup_index < g.OpenPopupStack.Size;
+        ++popup_index)
+    {
+        if (g.OpenPopupStack[popup_index].PopupId != popup_id)
+            continue;
+        ClosePopupToLevel(popup_index, true);
+        return;
+    }
+}
