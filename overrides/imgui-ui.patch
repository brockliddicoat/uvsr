+static void AnimateSliderGrab(
+    ImGuiWindow* window,
+    ImGuiContext& g,
+    ImGuiID id,
+    ImGuiAxis axis,
+    ImRect* grab_bb)
+{
+    if (grab_bb->Max[axis] <= grab_bb->Min[axis])
