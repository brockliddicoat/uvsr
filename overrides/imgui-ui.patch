+static void RenderGradientFrameOutline(
+    ImDrawList* draw_list,
+    const ImRect& bounding_box,
+    float rounding)
+{
+    const float thickness = 1.0f;
+    const float inset = thickness * 0.5f;
+    const ImRect outline_box(
+        bounding_box.Min + ImVec2(inset, inset),
+        bounding_box.Max - ImVec2(inset, inset));
+    if (outline_box.GetWidth() <= thickness ||
+        outline_box.GetHeight() <= thickness)
+    {
+        return;
+    }
+
+    const int vertex_start = draw_list->VtxBuffer.Size;
+    draw_list->AddRect(
+        outline_box.Min,
+        outline_box.Max,
+        IM_COL32_WHITE,
+        ImMax(0.0f, rounding - inset),
+        ImDrawFlags_RoundCornersAll,
+        thickness);
+    const int vertex_end = draw_list->VtxBuffer.Size;
+
+    const float gradient_extent = ImMax(outline_box.GetHeight(), 1.0f);
+    for (int vertex_index = vertex_start;
+        vertex_index < vertex_end;
+        ++vertex_index)
+    {
+        ImDrawVert& vertex = draw_list->VtxBuffer[vertex_index];
+        const float gradient_position = ImSaturate(
+            (vertex.pos.y - outline_box.Min.y) / gradient_extent);
+        vertex.col = ImGui::GetColorU32(ImVec4(
+            ImLerp(0.88f, 0.96f, gradient_position),
+            ImLerp(0.90f, 0.97f, gradient_position),
+            ImLerp(0.94f, 1.00f, gradient_position),
+            ImLerp(0.10f, 0.30f, gradient_position)));
+    }
+}
