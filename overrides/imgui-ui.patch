+static void ApplyDisabledGrayscale(ImVec4& color)
+{
+    ImGuiContext& g = *GImGui;
+    if ((g.CurrentItemFlags & ImGuiItemFlags_Disabled) == 0)
+        return;
+
+    const float luminance =
+        color.x * 0.299f +
+        color.y * 0.587f +
+        color.z * 0.114f;
+    color.x = luminance;
+    color.y = luminance;
+    color.z = luminance;
+}
