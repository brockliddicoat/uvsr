+static void RenderSubduedTreeNodeHighlight(
+    ImDrawList* draw_list,
+    ImRect bounding_box,
+    const ImVec4& top_color,
+    const ImVec4& bottom_color)
+{
+    const float inset = 0.5f;
+    bounding_box.Min += ImVec2(inset, inset);
+    bounding_box.Max -= ImVec2(inset, inset);
+    if (bounding_box.GetWidth() <= 1.0f ||
+        bounding_box.GetHeight() <= 1.0f)
+    {
+        return;
+    }
+
+    const float rounding = ImMin(
+        3.0f,
+        bounding_box.GetHeight() * 0.18f);
+    const float gradient_extent = ImMax(
+        bounding_box.GetHeight(),
+        1.0f);
+    const int fill_vertex_start = draw_list->VtxBuffer.Size;
+    draw_list->AddRectFilled(
+        bounding_box.Min,
+        bounding_box.Max,
+        IM_COL32_WHITE,
+        rounding,
+        ImDrawFlags_RoundCornersAll);
+    const int fill_vertex_end = draw_list->VtxBuffer.Size;
+    for (int vertex_index = fill_vertex_start;
+        vertex_index < fill_vertex_end;
+        ++vertex_index)
+    {
+        ImDrawVert& vertex = draw_list->VtxBuffer[vertex_index];
+        const float amount = ImSaturate(
+            (vertex.pos.y - bounding_box.Min.y) /
+            gradient_extent);
+        vertex.col = ImGui::GetColorU32(ImVec4(
+            ImLerp(top_color.x, bottom_color.x, amount),
+            ImLerp(top_color.y, bottom_color.y, amount),
+            ImLerp(top_color.z, bottom_color.z, amount),
+            ImLerp(top_color.w, bottom_color.w, amount)));
+    }
+
+    const int outline_vertex_start = draw_list->VtxBuffer.Size;
+    draw_list->AddRect(
+        bounding_box.Min,
+        bounding_box.Max,
+        IM_COL32_WHITE,
+        rounding,
+        ImDrawFlags_RoundCornersAll,
+        1.0f);
+    const int outline_vertex_end = draw_list->VtxBuffer.Size;
+    for (int vertex_index = outline_vertex_start;
+        vertex_index < outline_vertex_end;
+        ++vertex_index)
+    {
+        ImDrawVert& vertex = draw_list->VtxBuffer[vertex_index];
+        const float amount = ImSaturate(
+            (vertex.pos.y - bounding_box.Min.y) /
+            gradient_extent);
+        vertex.col = ImGui::GetColorU32(ImVec4(
+            ImLerp(0.82f, 0.91f, amount),
+            ImLerp(0.84f, 0.93f, amount),
+            ImLerp(0.88f, 0.97f, amount),
+            ImLerp(0.07f, 0.17f, amount)));
+    }
+}
