+static float GetAnimatedHighlightAmount(
+    ImGuiWindow* window,
+    ImGuiContext& g,
+    ImGuiID id,
+    bool highlighted,
+    float speed = 24.0f)
+{
+    ImGuiStorage& storage = window->StateStorage;
+    const ImGuiID amount_key = ImHashStr(
+        "##HighlightFadeAmount",
+        0,
+        id);
+    const ImGuiID frame_key = ImHashStr(
+        "##HighlightFadeFrame",
+        0,
+        id);
+    const float target = highlighted ? 1.0f : 0.0f;
+    float amount = storage.GetFloat(amount_key, 0.0f);
+    const int last_frame = storage.GetInt(frame_key, -2);
+    if (last_frame < g.FrameCount - 1)
+        amount = 0.0f;
+
+    amount = ImLerp(
+        amount,
+        target,
+        ImSaturate(g.IO.DeltaTime * speed));
+    if (ImFabs(target - amount) < 0.015f)
+        amount = target;
+    storage.SetFloat(amount_key, amount);
+    storage.SetInt(frame_key, g.FrameCount);
+    return amount;
+}
+
+static ImVec4 LerpWidgetColor(
+    const ImVec4& normal,
+    const ImVec4& interaction,
+    float amount)
+{
+    return ImVec4(
+        ImLerp(normal.x, interaction.x, amount),
+        ImLerp(normal.y, interaction.y, amount),
+        ImLerp(normal.z, interaction.z, amount),
+        ImLerp(normal.w, interaction.w, amount));
+}
