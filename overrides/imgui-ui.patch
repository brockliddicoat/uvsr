+
+    ImGuiStorage& storage = window->StateStorage;
+    const ImGuiID animation_key = ImHashStr(
+        "##SliderGrabAnimation",
+        0,
+        id);
+    const ImGuiID animation_frame_key = ImHashStr(
+        "##SliderGrabAnimationFrame",
+        0,
+        id);
+    const float target_position =
+        (grab_bb->Min[axis] + grab_bb->Max[axis]) * 0.5f;
+    float animated_position = storage.GetFloat(
+        animation_key,
+        target_position);
+    const int last_animation_frame = storage.GetInt(
+        animation_frame_key,
+        -2);
+    if (last_animation_frame < g.FrameCount - 1)
