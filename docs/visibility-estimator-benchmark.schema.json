{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/brockliddicoat/uvsr/blob/main/docs/visibility-estimator-benchmark.schema.json",
  "title": "UVSR visibility estimator benchmark",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "revision",
    "timestampUtc",
    "adapter",
    "driver",
    "scene",
    "camera",
    "configuration",
    "estimators"
  ],
  "properties": {
    "revision": { "type": "string", "minLength": 7 },
    "timestampUtc": { "type": "string", "format": "date-time" },
    "adapter": { "type": "string", "minLength": 1 },
    "driver": { "type": "string", "minLength": 1 },
    "scene": { "type": "string", "minLength": 1 },
    "camera": { "type": "string", "minLength": 1 },
    "configuration": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "width",
        "height",
        "preset",
        "radiusWorld",
        "thicknessWorld",
        "radialDistributionExponent",
        "minimumSamplesPerPixel",
        "maximumSamplesPerPixel",
        "adaptiveErrorStrength",
        "ambientOcclusionStrength",
        "indirectDiffuseIntensity",
        "bounceCount",
        "bounceContributionCutoff",
        "includeEmissiveSources",
        "emissiveSourceGain",
        "projection",
        "resolution",
        "scheduler",
        "adaptiveSparseSampling",
        "reconstructionEnabled",
        "temporalReconstruction",
        "temporalCurrentResponse",
        "spatialFiltering",
        "spatialFilter",
        "spatialRadius"
      ],
      "properties": {
        "width": { "type": "integer", "minimum": 1 },
        "height": { "type": "integer", "minimum": 1 },
        "preset": { "type": "string", "minLength": 1 },
        "radiusWorld": { "type": "number", "exclusiveMinimum": 0 },
        "thicknessWorld": { "type": "number", "minimum": 0 },
        "radialDistributionExponent": { "type": "number", "minimum": 0.5, "maximum": 4 },
        "minimumSamplesPerPixel": { "type": "integer", "minimum": 1, "maximum": 64 },
        "maximumSamplesPerPixel": { "type": "integer", "minimum": 1, "maximum": 64 },
        "adaptiveErrorStrength": { "type": "number", "minimum": 0, "maximum": 2 },
        "ambientOcclusionStrength": { "type": "number", "minimum": 0, "maximum": 2 },
        "indirectDiffuseIntensity": { "type": "number", "minimum": 0, "maximum": 10 },
        "bounceCount": { "type": "integer", "minimum": 1, "maximum": 4 },
        "bounceContributionCutoff": { "type": "number", "minimum": 0, "maximum": 0.02 },
        "includeEmissiveSources": { "type": "boolean" },
        "emissiveSourceGain": { "type": "number", "minimum": 0, "maximum": 10 },
        "projection": { "enum": ["perspective", "orthographic"] },
        "resolution": { "enum": ["full", "half", "quarter"] },
        "scheduler": {
          "enum": [
            "independent-hash-noise",
            "toroidal-blue-noise",
            "filter-adapted-spatiotemporal-noise"
          ]
        },
        "adaptiveSparseSampling": { "type": "boolean" },
        "reconstructionEnabled": { "type": "boolean" },
        "temporalReconstruction": { "type": "boolean" },
        "temporalCurrentResponse": { "type": "number", "minimum": 0.05, "maximum": 1 },
        "spatialFiltering": { "type": "boolean" },
        "spatialFilter": { "enum": ["joint-bilateral", "gaussian-joint-bilateral"] },
        "spatialRadius": { "type": "number", "minimum": 1, "maximum": 12 },
        "depthPath": { "enum": ["exact", "hierarchy"] },
        "rendererPath": { "enum": ["deferred", "forward"] },
        "consumers": { "enum": ["ao", "gi", "ao+gi"] }
      }
    },
    "estimators": {
      "type": "array",
      "minItems": 3,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "signedMeanAoBias",
          "aoRmse",
          "giLuminanceRmse",
          "giChromaError",
          "p95Error",
          "p99Error",
          "hdrFlipError",
          "staticTemporalVariance",
          "disocclusionError",
          "gpuMilliseconds",
          "registerCount",
          "occupancyPercent",
          "logicalTrafficBytes",
          "measuredTrafficBytes",
          "resourceMemoryBytes"
        ],
        "properties": {
          "name": { "enum": ["UniformProjectedAngle", "UniformSolidAngle", "CosineWeightedSolidAngle"] },
          "signedMeanAoBias": { "type": "number" },
          "aoRmse": { "type": "number", "minimum": 0 },
          "giLuminanceRmse": { "type": "number", "minimum": 0 },
          "giChromaError": { "type": "number", "minimum": 0 },
          "p95Error": { "type": "number", "minimum": 0 },
          "p99Error": { "type": "number", "minimum": 0 },
          "hdrFlipError": { "type": "number", "minimum": 0 },
          "staticTemporalVariance": { "type": "number", "minimum": 0 },
          "disocclusionError": { "type": "number", "minimum": 0 },
          "gpuMilliseconds": { "type": "number", "minimum": 0 },
          "registerCount": { "type": "integer", "minimum": 0 },
          "occupancyPercent": { "type": "number", "minimum": 0, "maximum": 100 },
          "logicalTrafficBytes": { "type": "integer", "minimum": 0 },
          "measuredTrafficBytes": { "type": "integer", "minimum": 0 },
          "resourceMemoryBytes": { "type": "integer", "minimum": 0 }
        }
      }
    },
    "screenshots": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "errorMaps": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "notes": { "type": "string" }
  }
}
